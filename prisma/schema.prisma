generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int    @id @default(autoincrement())
  name        String
  price       Float
  image       String
  description String
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])
}

model Category {
  id       Int    @id @default(autoincrement())
  name     String
  emoji    String
  slug     String @unique
  color    String
  pale     String
  gradient String
  products Product[]
}

model User {
  id       Int @id @default(autoincrement())
  email    String @unique
  password String
}